<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.startalk.startalk.word.mapper.WordMapper">

    <select id="selectByCategory" resultType="com.startalk.startalk.word.entity.Word">
        SELECT * FROM word
        WHERE deleted = 0
        AND category = #{category}
        ORDER BY id
    </select>

    <select id="selectByDifficulty" resultType="com.startalk.startalk.word.entity.Word">
        SELECT * FROM word
        WHERE deleted = 0
        AND difficulty = #{difficulty}
        ORDER BY id
    </select>

</mapper>